generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  student       Student?
  teacher       Teacher?
  notifications Notification[]
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model Student {
  id             String                 @id @default(cuid())
  userId         String                 @unique
  user           User                   @relation(fields: [userId], references: [id])
  admissionYear  String                 @default("2024-25")
  admissionNo    String                 @unique @default(cuid())
  class          String
  section        String
  rollNo         String                 @unique
  parentName   String
  contact      String
  address      String
  photoUrl     String?
  dob          DateTime
  attendance   Attendance[]
  results        Result[]
  payments       Payment[]
  submissions    AssignmentSubmission[]
  yearHistory    StudentYear[]
}

model Teacher {
  id               String               @id @default(cuid())
  userId           String               @unique
  user             User                 @relation(fields: [userId], references: [id])
  employeeId       String               @unique
  phone            String
  address          String
  qualification    String
  joiningDate      DateTime
  photoUrl         String?
  assignedClasses  TeacherClass[]
  assignments      Assignment[]
  attendance       TeacherAttendance[]
  salaryConfig     TeacherSalaryConfig?
  salaryPayments   SalaryPayment[]
  classTeacher     ClassTeacher?
}

model TeacherClass {
  id        String   @id @default(cuid())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  className String
  subjects  String[]

  @@unique([teacherId, className])
}

model ClassTeacher {
  id         String   @id @default(cuid())
  className  String   @unique
  teacherId  String   @unique
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  assignedAt DateTime @default(now())
  assignedBy String   @default("system")
}

model Attendance {
  id             String           @id @default(cuid())
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id])
  academicYearId String?
  date           DateTime
  status         AttendanceStatus
  markedBy       String
  createdAt      DateTime         @default(now())

  @@unique([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

model Result {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  subject       String
  examType      ExamType
  marksObtained Float
  totalMarks    Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subject, examType])
}

enum ExamType {
  UNIT_TEST
  HALF_YEARLY
  ANNUAL
}

model FeeStructure {
  id             String        @id @default(cuid())
  class          String
  type           String
  amount         Float
  dueDate        DateTime
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  studentId         String
  student           Student       @relation(fields: [studentId], references: [id])
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  amount            Float
  status            PaymentStatus @default(PENDING)
  type              String
  verifiedAt        DateTime?
  createdAt         DateTime      @default(now())
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model Notice {
  id          String    @id @default(cuid())
  title       String
  body        String
  category    String
  targetRole  String    @default("ALL")
  postedBy    String
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  targetId    String
  note        String?
  timestamp   DateTime @default(now())
}

model Assignment {
  id          String                 @id @default(cuid())
  teacherId   String
  teacher     Teacher                @relation(fields: [teacherId], references: [id])
  className   String
  subject     String
  title       String
  description String
  dueDate     DateTime
  fileUrl     String?
  fileName    String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id])
  fileUrl      String
  fileName     String
  fileSize     Int
  status       SubmissionStatus @default(SUBMITTED)
  teacherNote  String?
  submittedAt  DateTime         @default(now())
  reviewedAt   DateTime?

  @@unique([assignmentId, studentId])
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  COMPLETED
}

// ━━━ Teacher Salary Management ━━━

model TeacherAttendance {
  id        String                  @id @default(cuid())
  teacherId String
  teacher   Teacher                 @relation(fields: [teacherId], references: [id])
  date      DateTime
  status    TeacherAttendanceStatus
  markedBy  String
  note      String?
  createdAt DateTime                @default(now())

  @@unique([teacherId, date])
}

enum TeacherAttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  PAID_LEAVE
  UNPAID_LEAVE
}

model TeacherSalaryConfig {
  id                    String   @id @default(cuid())
  teacherId             String   @unique
  teacher               Teacher  @relation(fields: [teacherId], references: [id])
  baseSalary            Float
  accountHolderName     String
  bankAccountNumber     String
  ifscCode              String
  bankName              String
  razorpayContactId     String?
  razorpayFundAccountId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SalaryPayment {
  id               String              @id @default(cuid())
  teacherId        String
  teacher          Teacher             @relation(fields: [teacherId], references: [id])
  academicYearId   String?
  academicYear     AcademicYear?       @relation(fields: [academicYearId], references: [id])
  month            Int
  year             Int
  baseSalary       Float
  totalWorkingDays Int
  presentDays      Float
  halfDays         Float
  paidLeaveDays    Float
  unpaidLeaveDays  Float
  absentDays       Float
  deductionAmount  Float
  netSalary        Float
  razorpayPayoutId String?
  status           SalaryPaymentStatus @default(PENDING)
  failureReason    String?
  processedBy      String
  processedAt      DateTime?
  createdAt        DateTime            @default(now())

  @@unique([teacherId, month, year])
}

enum SalaryPaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ─── ACADEMIC YEAR ───────────────────────────

model AcademicYear {
  id            String          @id @default(cuid())
  year          String          @unique // e.g. "2024-25"
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean         @default(false)
  isClosed      Boolean         @default(false)
  closedAt      DateTime?
  closedBy      String?
  createdAt     DateTime        @default(now())
  students      StudentYear[]
  feeStructures FeeStructure[]
  salaryPayments SalaryPayment[]
}

// Links student to their class in a specific year
model StudentYear {
  id             String            @id @default(cuid())
  studentId      String
  student        Student           @relation(fields: [studentId], references: [id])
  academicYearId String
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])
  class          String
  section        String
  rollNo         String
  status         StudentYearStatus @default(ACTIVE)
  promotedAt     DateTime?
  promotedBy     String?
  createdAt      DateTime          @default(now())
  
  @@unique([studentId, academicYearId])
}

enum StudentYearStatus {
  ACTIVE
  PROMOTED
  DETAINED
  TRANSFERRED
  LEFT
}

// ─── NOTIFICATIONS ───────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  body       String
  link       String?          // where to navigate on click
  isRead     Boolean          @default(false)
  readAt     DateTime?
  metadata   Json?            // extra data (assignmentId, paymentId etc.)
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
}

enum NotificationType {
  ASSIGNMENT_POSTED
  FEE_DUE_REMINDER
  ATTENDANCE_ABSENT
  RESULT_PUBLISHED
  SALARY_PROCESSED
  NOTICE_PUBLISHED
  YEAR_PROMOTED
  GENERAL
}
