# Database Variables (Required)
DATABASE_URL="postgresql://user:password@host/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname"

# Authentication (Required)
# Generate a secret via: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-32-character-secret"
NEXTAUTH_URL="http://localhost:3000"

# Payment Processing (Razorpay) (Required for Fee Portal)
RAZORPAY_KEY_ID="rzp_test_YourKeyID"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_custom_webhook_secret"

# Storage (Supabase) (Required for Photo Uploads)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ⚠️ IMPORTANT:
# - NEXT_PUBLIC_SUPABASE_URL & NEXT_PUBLIC_SUPABASE_ANON_KEY: Used in client components
# - SUPABASE_SERVICE_ROLE_KEY: Used ONLY in API routes/server code (NEVER expose to browser)
#
# How to get these keys:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings → API
# 4. Copy the following:
#    - Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY (keep secret!)
