# Database Variables (Required)
DATABASE_URL="postgresql://user:password@host/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname"

# Authentication (Required)
# Generate a secret via: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-32-character-secret"
NEXTAUTH_URL="http://localhost:3000"

# Payment Processing (Razorpay) (Required for Fee Portal)
RAZORPAY_KEY_ID="rzp_test_YourKeyID"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_custom_webhook_secret"

# Storage (Supabase) (Required for Photo Uploads)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
